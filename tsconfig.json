{
  "compilerOptions": {
    "lib": ["ESNext"],
    "target": "ESNext",
    "module": "Preserve",
    "moduleDetection": "force",
    "moduleResolution": "bundler",
    "allowImportingTsExtensions": true,
    "verbatimModuleSyntax": true,
    "resolveJsonModule": true,
    "noEmit": true,
    "strict": true,
    "skipLibCheck": true,
    "noFallthroughCasesInSwitch": true,
    "noUncheckedIndexedAccess": true,
    "noImplicitOverride": true,
    "baseUrl": ".",
    "paths": {
      "fastboot-bun-ts/fastboot": ["./apps/fastboot/src/index.ts"],
      "fastboot-bun-ts/usb": ["./apps/usb/src/index.ts"],
      "fastboot-bun-ts/shared/*": ["./packages/shared/src/*.ts"],
      "fastboot-bun-ts/contracts/*": ["./packages/contracts/src/*.ts"]
    }
  },
  "include": [
    "index.ts",
    "apps/**/*.ts",
    "packages/**/*.ts"
  ]
}
